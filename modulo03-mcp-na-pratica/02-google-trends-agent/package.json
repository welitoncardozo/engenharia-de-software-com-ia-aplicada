{
  "name": "transforming-services-into-tools",
  "version": "1.0.0",
  "description": "LangGraph agent that wraps SerpAPI Google Trends as a LangChain tool to answer video content strategy questions",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file .env src/index.ts",
    "dev": "node --watch --inspect --env-file .env src/index.ts",
    "test": "node --env-file .env --test tests/**/*.test.ts",
    "test:dev": "node --inspect --env-file .env --test --watch tests/**/*.test.ts",
    "test:unit:dev": "node --inspect --test --watch tests/**/*unit.test.ts",
    "test:unit": "node --inspect --test tests/**/*unit.test.ts",
    "test:e2e:dev": "node --inspect --env-file .env --test --watch tests/**/*e2e.test.ts",
    "test:e2e": "node --inspect --env-file .env --test tests/**/*e2e.test.ts",
    "langgraph:serve": "npx @langchain/langgraph-cli dev"
  },
  "keywords": [
    "langchain",
    "prompt-chaining",
    "article-generator",
    "openrouter",
    "ollama"
  ],
  "author": "erickwendel",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.19",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.5",
    "fastify": "^5.7.4",
    "langchain": "^1.2.17",
    "serpapi": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.12"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
