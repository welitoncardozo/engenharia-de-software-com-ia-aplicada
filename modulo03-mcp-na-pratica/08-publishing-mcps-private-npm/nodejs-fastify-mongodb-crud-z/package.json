  "main": "index.js",
  "scripts": {
    "start": "DB_NAME=customers node src/index.js",
    "dev": "DB_NAME=customers node --watch src/index.js",
    "test": "NODE_ENV=test node --experimental-test-coverage --test test/api.test.js",
